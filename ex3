<head>
<meta charset="UTF-8">
<style>
table {
  font-family: Arial, Helvetica, sans-serif;
  border-collapse: collapse;
  width: 100%;
}

/* 表頭 */
th {
  padding: 12px;
  text-align: left;
  color: white;
  background: linear-gradient(to right, #0aa06e, #19b37a);
}

/* 儲存格 */
td {
  border: 1px solid #ddd;
  padding: 10px;
}

/* 斑馬紋 */
tr:nth-child(even) {
  background-color: #f2f2f2;
}

/* 滑鼠效果 */
tr:hover {
  background-color: #ddd;
}
</style>
</head>

